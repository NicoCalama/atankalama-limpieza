# === Aplicación ===
APP_NAME="Atankalama Aplicacion Limpieza"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=America/Santiago

# === Sesiones ===
SESSION_SECRET=cambiar_por_string_aleatorio_largo_de_64_caracteres
SESSION_LIFETIME_MINUTES=480

# === Rate limiting de login (throttle por rut|ip) ===
# Máximo de intentos fallidos permitidos dentro de la ventana antes de bloquear.
LOGIN_THROTTLE_MAX_INTENTOS=5
# Ventana deslizante en minutos sobre la que se cuentan los intentos fallidos.
LOGIN_THROTTLE_VENTANA_MINUTOS=15
# Tiempo de bloqueo informativo (minutos) — actualmente se calcula dinámicamente
# desde el intento más antiguo dentro de la ventana, así que este valor sirve
# de referencia/documentación para operación.
LOGIN_THROTTLE_LOCKOUT_MINUTOS=15

# === Base de datos ===
DB_PATH=database/atankalama.db

# === Cloudbeds API — Atankalama Inn (Chorrillos 558) ===
CLOUDBEDS_API_KEY_INN=tu_api_key_atankalama_inn_aqui
CLOUDBEDS_PROPERTY_ID_INN=property_id_atankalama_inn

# === Cloudbeds API — Atankalama (1 Sur 858) ===
CLOUDBEDS_API_KEY_PRINCIPAL=tu_api_key_atankalama_principal_aqui
CLOUDBEDS_PROPERTY_ID_PRINCIPAL=property_id_atankalama_principal

# === Cloudbeds común ===
CLOUDBEDS_BASE_URL=https://api.cloudbeds.com/api/v1
CLOUDBEDS_TIMEOUT_SECONDS=10
CLOUDBEDS_MAX_RETRIES=3

# === Claude API (copilot IA) ===
CLAUDE_API_KEY=sk-ant-api03-tu_clave_aqui
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=2048

# === Sincronización Cloudbeds (cron) ===
SYNC_HOUR_MORNING=09
SYNC_HOUR_EVENING=21

# === Alertas predictivas ===
ALERTA_PREDICTIVA_MARGEN_MINUTOS=15
ALERTA_PREDICTIVA_LIMPIEZAS_MINIMAS_HISTORIA=5

# === Email SMTP ===
# Dejar SMTP_HOST vacío para deshabilitar el envío de emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password_aqui
SMTP_FROM=tu_correo@gmail.com
SMTP_FROM_NAME="Atankalama Limpieza"

# === Push Notifications (VAPID) ===
VAPID_PUBLIC_KEY=generar_con_scripts/generate-vapid-keys.php
VAPID_PRIVATE_KEY=generar_con_scripts/generate-vapid-keys.php
VAPID_SUBJECT=mailto:admin@tudominio.cl

# === Retención de datos (RGPD — minimización temporal) ===
# Días antes de borrar logs/notificaciones/etc. desde scripts/cleanup-retention.php.
# Logs INFO y WARNING (default 90 días)
LOG_RETENTION_DAYS_INFO=90
# Logs de ERROR se conservan más tiempo para análisis post-incidente (default 365)
LOG_RETENTION_DAYS_ERROR=365
# Auditoría de acciones de usuario: 0 = nunca borrar (default por compliance).
# Subir solo si hay obligación legal de purgar tras un periodo concreto.
AUDIT_RETENTION_DAYS=0
# Conversaciones del copilot IA y sus mensajes (cascade) (default 365)
COPILOT_RETENTION_DAYS=365
# Notificaciones leídas del centro de notificaciones (las no leídas no se tocan) (default 90)
NOTIFICATIONS_RETENTION_DAYS=90
# Sesiones expiradas huérfanas que el sliding window no limpió (default 7)
SESSION_CLEANUP_DAYS=7
# Intentos de login antiguos (la ventana de throttle es 15 min, 1 día sobra) (default 1)
THROTTLE_CLEANUP_DAYS=1
