# .env.production.example — plantilla para el .env de PRODUCCIÓN (cPanel).
#
# La app vive en https://atankalama.com/limpieza (patrón Maisterchef):
#   public_html/limpieza/            ← docroot (stub index.php + assets)
#   public_html/limpieza/app_core/   ← código completo (denegado por web)
#
# El .env real va en app_core/.env:
#   1. Copiar esta plantilla como app_core/.env (File Manager o FTP)
#   2. Completar los valores reales (API keys desde 1Password / Nicolás)
#   3. chmod 600 app_core/.env
#
# IMPORTANTE:
#   - Nunca commitear .env al repo (está en .gitignore).
#   - Generar SESSION_SECRET con: openssl rand -hex 32
#   - Si falta este archivo, los scripts caen EN SILENCIO a SQLite y crean una
#     BD fantasma en app_core/database/ — verificar tras el deploy (runbook).

# === Aplicación ===
APP_NAME="Atankalama Limpieza"
APP_ENV=production
APP_DEBUG=false
# URL pública completa (con subpath, sin barra final) — se usa en los links de
# los emails de credenciales.
APP_URL=https://atankalama.com/limpieza
APP_TIMEZONE=America/Santiago
# Prefijo de URL bajo el que vive la app (subpath del dominio). Toda la
# navegación, la API, la PWA y las cookies lo respetan. En dev queda vacío.
BASE_PATH=/limpieza

# === Sesiones ===
# Generar con: openssl rand -hex 32
SESSION_SECRET=cambiar_por_string_aleatorio_generado_con_openssl_rand_hex_32
SESSION_LIFETIME_MINUTES=480

# === Rate limiting de login (throttle por rut|ip) ===
LOGIN_THROTTLE_MAX_INTENTOS=5
LOGIN_THROTTLE_VENTANA_MINUTOS=15

# === Base de datos (MariaDB — cPanel, BD COMPARTIDA con Maisterchef) ===
# Reusa el usuario MySQL de Maisterchef (tiene ALL PRIVILEGES sobre la base
# compartida cat6852_australia). El prefijo limpieza_ mantiene las tablas de
# atankalama separadas de las maisterchef_.
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cat6852_australia
DB_CHARSET=utf8mb4
# Informativa: el DSN solo usa DB_CHARSET; la collation la fija el schema.
DB_COLLATION=utf8mb4_unicode_ci
DB_PREFIX=limpieza_
# Credenciales del usuario MySQL (reusar el de Maisterchef) — completar en el
# .env real del servidor, nunca commitear el valor:
DB_USERNAME=
DB_PASSWORD=
# Si el hosting expone socket UNIX (más rápido que TCP), setéalo:
# DB_SOCKET=/var/lib/mysql/mysql.sock

# === Cloudbeds API — Atankalama INN (Chorrillos 558) ===
CLOUDBEDS_API_KEY_INN=
CLOUDBEDS_PROPERTY_ID_INN=

# === Cloudbeds API — Atankalama (1 Sur 858) ===
CLOUDBEDS_API_KEY_PRINCIPAL=
CLOUDBEDS_PROPERTY_ID_PRINCIPAL=

# === Cloudbeds común ===
CLOUDBEDS_BASE_URL=https://api.cloudbeds.com/api/v1.1
CLOUDBEDS_TIMEOUT_SECONDS=10
# true = simula las ESCRITURAS a Cloudbeds (loguea sin tocar la red); las
# lecturas no se afectan. Útil para validar el deploy sin ensuciar producción.
CLOUDBEDS_DRY_RUN=false
# La cadencia del sync NO se configura acá: el cron tickea */10 y el script se
# auto-regula por cloudbeds_config.sync_intervalo_minutos (editable por API).

# === Claude API (copilot IA) ===
# Muestra/oculta el FAB del copilot en la UI. Déjalo en false hasta conectar
# CLAUDE_API_KEY y validar el copilot (el backend sigue gateado por permiso).
COPILOT_HABILITADO=false
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=2048

# === Email ===
# MAIL_TRANSPORT=mail usa mail() nativo del servidor: en cPanel, Exim entrega el
# correo del propio dominio sin credenciales SMTP. Solo requiere SMTP_FROM (una
# casilla creada en cPanel, p. ej. sistema@atankalama.com) y SMTP_FROM_NAME.
# Sin SMTP_FROM el envío queda deshabilitado EN SILENCIO (los usuarios nuevos y
# la recuperación de clave no mandan correo).
# Alternativa: MAIL_TRANSPORT=smtp con SMTP_HOST/USER/PASS (credenciales cPanel).
MAIL_TRANSPORT=mail
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ENCRYPTION=tls
SMTP_FROM=COMPLETAR_casilla_del_dominio
SMTP_FROM_NAME="Atankalama Limpieza"

# === Notificaciones push (Web Push / VAPID) ===
# Generar el par de claves con: php scripts/generate-vapid-keys.php
# Sin estas claves el push queda deshabilitado en silencio (no crashea).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@atankalama.cl

# === Retención de datos (RGPD — minimización temporal) ===
# Usadas por scripts/cleanup-retention.php (cron diario 03:00).
# Logs INFO y WARNING (default 90 días)
LOG_RETENTION_DAYS_INFO=90
# Logs de ERROR se conservan más tiempo para análisis post-incidente (default 365)
LOG_RETENTION_DAYS_ERROR=365
# Auditoría de acciones de usuario: 0 = nunca borrar (default por compliance).
AUDIT_RETENTION_DAYS=0
# Conversaciones del copilot IA y sus mensajes (cascade) (default 365)
COPILOT_RETENTION_DAYS=365
# Notificaciones leídas del centro de notificaciones (default 90)
NOTIFICATIONS_RETENTION_DAYS=90
# Sesiones expiradas huérfanas (default 7)
SESSION_CLEANUP_DAYS=7
# Intentos de login antiguos para throttle (default 1)
THROTTLE_CLEANUP_DAYS=1
