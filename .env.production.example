# .env.production.example — plantilla para el archivo .env del VPS.
#
# Copia a .env en la raíz del proyecto en el servidor:
#   cp .env.production.example .env
#   nano .env    # completar los valores reales
#   chmod 600 .env
#
# IMPORTANTE:
#   - Nunca commitees .env al repo. Está en .gitignore.
#   - Genera SESSION_SECRET con:
#       openssl rand -hex 32
#   - Las API keys reales vienen de 1Password / el admin (Nicolás).

# === Aplicación ===
APP_NAME="Atankalama Limpieza"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://limpieza.atankalama.cl
APP_TIMEZONE=America/Santiago

# === Sesiones ===
# Generar con: openssl rand -hex 32
SESSION_SECRET=cambiar_por_string_aleatorio_generado_con_openssl_rand_hex_32
SESSION_LIFETIME_MINUTES=480

# === Base de datos ===
# Ruta relativa al root del proyecto.
DB_PATH=database/atankalama.db

# === Cloudbeds API — Atankalama INN (Chorrillos 558) ===
CLOUDBEDS_API_KEY_INN=
CLOUDBEDS_PROPERTY_ID_INN=

# === Cloudbeds API — Atankalama (1 Sur 858) ===
CLOUDBEDS_API_KEY_PRINCIPAL=
CLOUDBEDS_PROPERTY_ID_PRINCIPAL=

# === Cloudbeds común ===
CLOUDBEDS_BASE_URL=https://api.cloudbeds.com/api/v1
CLOUDBEDS_TIMEOUT_SECONDS=10
CLOUDBEDS_MAX_RETRIES=3

# === Claude API (copilot IA) ===
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=2048

# === Sincronización Cloudbeds (horas del cron) ===
SYNC_HOUR_MORNING=09
SYNC_HOUR_EVENING=21

# === Alertas predictivas ===
ALERTA_PREDICTIVA_MARGEN_MINUTOS=15
ALERTA_PREDICTIVA_LIMPIEZAS_MINIMAS_HISTORIA=5
