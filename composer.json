{
    "name": "atankalama/limpieza",
    "description": "Aplicación de gestión de limpieza hotelera para Atankalama Corp",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "minishlink/web-push": "^10.0",
        "phpmailer/phpmailer": "^7.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "suggest": {
        "ext-pdo_mysql": "Requerido en producción (MariaDB en cPanel); verificar en MultiPHP INI",
        "ext-curl": "Cliente HTTP (Cloudbeds, Claude API, web-push)",
        "ext-zip": "No requerido: el build de deploy usa tar.exe (libarchive) en Windows"
    },
    "autoload": {
        "psr-4": {
            "Atankalama\\Limpieza\\": "src/"
        },
        "files": [
            "src/Core/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Atankalama\\Limpieza\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "init-db": "php scripts/init-db.php",
        "test": "phpunit tests/",
        "serve": "php -S localhost:8000 -t public/",
        "lint-urls": "php scripts/lint-url-basepath.php",
        "lint-tokens": "php scripts/lint-prefix-tokens.php",
        "build-cpanel": "php scripts/build-cpanel-zip.php"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
