{
    "name": "atankalama/limpieza",
    "description": "Aplicación de gestión de limpieza hotelera para Atankalama Corp",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Atankalama\\Limpieza\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Atankalama\\Limpieza\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "init-db": "php scripts/init-db.php",
        "test": "phpunit tests/",
        "serve": "php -S localhost:8000 -t public/"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
